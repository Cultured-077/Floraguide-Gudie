{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Plant": {
      "title": "Plant",
      "description": "A plant in the user's collection",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "scientificName": { "type": "string" },
        "description": { "type": "string" },
        "careInstructions": { "type": "string" },
        "imageUrl": { "type": "string" },
        "identifiedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in a chat thread",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/users/{userId}/plants/{plantId}": {
      "schema": "Plant",
      "description": "Plants owned by a user"
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "Chat messages for a user's gardening assistant"
    }
  }
}
